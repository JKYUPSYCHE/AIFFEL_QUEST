   "id": "a8af5c73",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 거래시간 정보에서 시각 정보만 추출\n",
    "cc_df['hour'] = pd.to_datetime(cc_df['trans_date_trans_time'],format='%Y-%m-%d %H:%M:%S').dt.hour\n",
    "\n",
    "# 결제 시각에 따라 분류하기 위한 함수\n",
    "def hour_func(x):\n",
    "    if (x >= 6) & (x < 12):\n",
    "        return 'morning'\n",
    "    elif (x >= 12) & (x < 18):\n",
    "        return 'afternoon'\n",
    "    elif (x >= 18) & (x < 23):\n",
    "        return 'night'\n",
    "    else:\n",
    "        return 'evening'\n",
    "    \n",
    "cc_df['hour_cat'] = cc_df['hour'].apply(hour_func) # 함수 적용"
   ]
  },

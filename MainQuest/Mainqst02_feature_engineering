   "source": [
    "## 거래 금액 z-scoring\n",
    "이상 거래의 경우 거래 금액이 평균보다 지나치게 높을 수 있다"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 46,
   "id": "66665ad5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 결제금액(amt)의 z-score를 계산하여 저장\n",
    "amt_info = cc_df.groupby('cc_num')['amt'].agg(['mean','std']).reset_index()\n",
    "cc_df = cc_df.merge(amt_info, on='cc_num', how='left')\n",
    "cc_df['amt_z'] = (cc_df['amt'] - cc_df['mean']) / cc_df['std']\n",
    "\n",
    "cc_df.drop(['mean','std'], axis = 1, inplace = True) # 계산 후 불필요한 컬럼 제거"
   ]
